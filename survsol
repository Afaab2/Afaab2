}

// ── LOGS & EFFECTS ───────────────────────────────────
function addLog(msg,type='info'){
  const log=document.getElementById('combatLog');
  const el=document.createElement('div');el.className='clog-entry '+type;el.textContent=msg;
  log.prepend(el);setTimeout(()=>el.remove(),6100);
