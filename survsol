// ── BOT TICK ─────────────────────────────────────────
function tickEntity(b,dt){
  if(b.state==='dead')return;
  const now=performance.now();
  if(b.stunTimer>0){
    b.stunTimer=Math.max(0,b.stunTimer-dt);
    b.hp=Math.min(b.maxHp,b.hp+CFG.REGEN_HP*dt/1000);
    if(b.slowTimer>0)b.slowTimer-=dt;
    return;
  }
  b.wanderTick-=dt;
  const dp=dist(b,player);
  if(b.isHero){
    let cl=player,cd=dp;
    bots.forEach(o=>{if(o.state!=='dead'){const d2=dist(b,o);if(d2<cd){cd=d2;cl=o;}}});
    b.state='chase';b.target=cl;
  }else{
    if(b.hp<b.maxHp*.25)b.state='flee';
    else if(dp<5){b.state='chase';b.target=player;}
    else{
      let cl=null,cd=6;
      bots.forEach(o=>{if(o!==b&&o.state!=='dead'&&!o.isHero){const d2=dist(b,o);if(d2<cd){cd=d2;cl=o;}}});
      if(cl){b.state='chase';b.target=cl;}else{b.state='wander';b.target=null;}
    }
  }
  let tx=b.x,ty=b.y;
  const spd=b.spd*(b.slowTimer>0?.4:1);
  if(b.state==='chase'&&b.target){
    const dx=b.target.x-b.x,dy=b.target.y-b.y,d=Math.sqrt(dx*dx+dy*dy)||1;
    if(d>0.9){tx+=dx/d*spd*(dt/1000);ty+=dy/d*spd*(dt/1000);}
  }else if(b.state==='flee'){
    const dx=b.x-player.x,dy=b.y-player.y,d=Math.sqrt(dx*dx+dy*dy)||1;
    tx+=dx/d*spd*(dt/1000)*1.4;ty+=dy/d*spd*(dt/1000)*1.4;
  }else{
    if(b.wanderTick<=0){b._wdx=(Math.random()-.5)*2;b._wdy=(Math.random()-.5)*2;b.wanderTick=1500+Math.random()*2000;}
    tx+=b._wdx*spd*(dt/1000);ty+=b._wdy*spd*(dt/1000);
  }
  tx=Math.max(.5,Math.min(CFG.MAP_W-.5,tx));ty=Math.max(.5,Math.min(CFG.MAP_H-.5,ty));
  if(isPassable(tx|0,ty|0)){b.x=tx;b.y=ty;}
  if(b.state==='chase'&&b.target&&dist(b,b.target)<1.3&&now-b.lastAtk>1200){
    b.lastAtk=now;dealDamage(b,b.target,b.atk);
  }
  WORLD.traps.forEach((trap,i)=>{
    if(trap.owner!==b.id&&dist(b,{x:trap.x+.5,y:trap.y+.5})<.8){
      dealDamage({name:'TRAP',id:'_trap'},b,trap.dmg);
      b.stunTimer=CFG.TRAP_STUN_MS;
      addLog('🪤 '+b.name+' TRAPPED & STUNNED 5s!','dmg');
      WORLD.traps.splice(i,1);
    }
  });
  b.hp=Math.min(b.maxHp,b.hp+CFG.REGEN_HP*dt/1000);
  b.mp=Math.min(b.maxMp,b.mp+CFG.REGEN_MP*dt/1000);
  if(b.slowTimer>0)b.slowTimer-=dt;
}

function tickBots(dt){
  bots.forEach(b=>tickEntity(b,dt));
  if(heroEntity&&heroEntity.state!=='dead')tickEntity(heroEntity,dt);
}

