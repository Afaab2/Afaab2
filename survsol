// ── COMBAT ───────────────────────────────────────────
function calcDmg(attacker,rawDmg){
  // Apply upgrade multiplier if attacker is player
  if(attacker===player){
    // Sum all owned upgrades' bonus damage as flat multiplier
    let mult=1.0;
    player.inventory.forEach(inv=>{
      const upg=upgrades[inv.id];
      if(upg&&upg.level>0){
        mult += upg.level * (CFG.UPGRADE_DMG_BONUS/100);
      }
    });
    return rawDmg * mult;
  }
  return rawDmg;
}

function dealDamageRaw(attacker,victim,rawDmg){
  if(victim.state==='dead')return;
  const def=victim.def||0,absorb=victim.shieldAbsorb||0;
  let dmg=Math.max(1,rawDmg-def);
  if(absorb>0){const ab=Math.min(absorb,dmg);victim.shieldAbsorb-=ab;dmg-=ab;}
  victim.hp-=dmg;
  victim.lastDmgBy=attacker;
  spawnFloatDmg(victim,'-'+Math.ceil(dmg),attacker===player?'#ff4466':attacker&&attacker.isHero?'#c77dff':'#ffd166');
  if(victim===player)updateHUD();
  if(victim.hp<=0)handleDeath(attacker,victim);
}

function dealDamage(attacker,victim,rawDmg){
  if(victim.state==='dead')return;
  const boosted=calcDmg(attacker,rawDmg);
  const def=victim.def||0,absorb=victim.shieldAbsorb||0;
  let dmg=Math.max(1,boosted-def);
  if(absorb>0){const ab=Math.min(absorb,dmg);victim.shieldAbsorb-=ab;dmg-=ab;}
  victim.hp-=dmg;
  victim.lastDmgBy=attacker;
  const dmgStr='-'+Math.ceil(dmg)+(attacker===player&&hasUpgrades()?'✨':'');
  spawnFloatDmg(victim,dmgStr,attacker===player?'#ff4466':attacker&&attacker.isHero?'#c77dff':'#ffd166');
  if(victim===player){addLog('💥 '+attacker.name+' hit you for '+Math.ceil(dmg),'dmg');updateHUD();}
  else if(attacker===player){addLog('⚔️ Hit '+victim.name+' for '+Math.ceil(dmg)+(hasUpgrades()?'✨':''),'dmg');player.xp+=CFG.XP_PER_HIT;checkLevelUp();}
  if(victim.hp<=0)handleDeath(attacker,victim);
}

function hasUpgrades(){
  return player.inventory.some(inv=>{const u=upgrades[inv.id];return u&&u.level>0;});
}

function handleDeath(killer,victim){
  victim.hp=0;
  if(victim.isHero){
    heroEntity.state='dead';
    const last=victim.lastDmgBy;
    if(last===player&&player.level>=CFG.HERO_AURA_MIN&&player.level<=CFG.HERO_AURA_MAX){
      player.sol+=CFG.HERO_KILL_REWARD;
      addLog('👑 HERO SLAIN! +0.5 SOL!','loot');
      showToast('👑 HERO SLAIN! +0.5 SOL!','hero');
      updateTopBar();updateButtons();
    }else if(last===player){
      addLog('👑 Hero slain — reward only for LV 3-5','info');
    }else{
      addLog('👑 Hero was slain','hero');
    }
    heroEntity=null;return;
  }
  const loot=victim.sol*CFG.LOOT_RATE;victim.sol-=loot;
  if(killer===player){
    player.kills++;player.sol+=loot;player.xp+=CFG.XP_PER_KILL;
    addLog('💀 KILLED '+victim.name+' +'+loot.toFixed(4)+' SOL','loot');
    showToast('KILL! +'+loot.toFixed(4)+' SOL','suc');
    checkLevelUp();updateHUD();updateTopBar();
    checkUpgradeUnlock();   // check if new kill threshold reached
    updateButtons();
  }else if(victim===player){
    addLog('💀 KILLED BY '+killer.name+' -'+loot.toFixed(4)+' SOL','dmg');
    showToast('YOU DIED! RESPAWNING...','err');
    setTimeout(respawnPlayer,3000);
  }
  if(victim!==player){
    victim.state='dead';
    setTimeout(()=>{const i=bots.indexOf(victim);if(i>-1){bots.splice(i,1);bots.push(createBot(Date.now()%1000));}},5000);
  }
  updatePlayersList();
}

function respawnPlayer(){
  let rx,ry;do{rx=2+Math.random()*(CFG.MAP_W-4)|0;ry=2+Math.random()*(CFG.MAP_H-4)|0;}while(!isPassable(rx,ry));
  player.x=rx+.5;player.y=ry+.5;player.hp=player.maxHp*.6;player.mp=player.maxMp;player.stunTimer=0;
  addLog('♻️ RESPAWNED','info');updateHUD();
}

function checkLevelUp(){
  while(player.xp>=player.xpNext){
    player.xp-=player.xpNext;player.level++;player.xpNext=player.level*100;
    player.maxHp+=10;player.hp=player.maxHp;player.maxMp+=5;player.mp=player.maxMp;
    player.atk+=3;player.def+=1;
    addLog('⭐ LEVEL UP! LV.'+player.level,'info');showToast('LEVEL UP! LV.'+player.level,'suc');
    updateHUD();updateTopBar();
    if(player.level%CFG.HERO_LEVEL_TRIGGER===0&&player.level!==heroLastLevel){
      heroLastLevel=player.level;
      if(!heroEntity||heroEntity.state==='dead'){setTimeout(spawnHeroBoss,2000);addLog('👑 Hero spawning soon...','hero');}
    }
  }
}

// ── UPGRADE SYSTEM ───────────────────────────────────
function checkUpgradeUnlock(){
  // Check if player.kills has crossed the next threshold
  while(player.kills>=upgradeNextKillThreshold){
    upgradeTokens++;
    const prev=upgradeNextKillThreshold;
    upgradeNextKillThreshold=nextThreshold(upgradeNextKillThreshold, upgradeTokens);
    addLog(`⬆️ UPGRADE UNLOCKED! (${prev} kills) Token #${upgradeTokens}`,'upg');
    showToast('⬆️ UPGRADE AVAILABLE! 0.02 SOL','upg');
    // Show upgrade banner
    document.getElementById('upgradeBanner').style.display='block';
    setTimeout(()=>document.getElementById('upgradeBanner').style.display='none',5000);
  }
  updateUpgradeSection();
  updateButtons();
}

function updateUpgradeSection(){
  const sec=document.getElementById('upgradeSection');
  const hasOwned=player.inventory.length>0;
  sec.style.display=hasOwned?'block':'none';

  const kills=player.kills;
  const nextThresh=upgradeNextKillThreshold;
  const prevThresh=upgradeTokens===0?0:(nextThresh-4); // reverse: approximate prev threshold
  const progress=Math.min(100,((kills-(prevThresh))/Math.max(1,(nextThresh-prevThresh)))*100);

  document.getElementById('upgKillsFill').style.width=progress+'%';
  document.getElementById('upgTierBadge').textContent='TIER '+getMaxUpgradeLevel();
  if(upgradeTokens>0){
    document.getElementById('upgInfo').innerHTML=`<span style="color:var(--purple)">${upgradeTokens} UPGRADE(S) READY! → 0.02 SOL each</span>`;
  }else{
    document.getElementById('upgInfo').textContent=`${kills} kills → ${nextThresh} for next upgrade`;
  }
}

function getMaxUpgradeLevel(){
  let max=0;
  player.inventory.forEach(inv=>{const u=upgrades[inv.id];if(u&&u.level>max)max=u.level;});
  return max;
}

function openUpgradeModal(){
  if(upgradeTokens<=0){
    showToast('No upgrades available yet!','err');
    return;
  }
  const ownedItems=player.inventory.filter((inv,i,arr)=>arr.findIndex(a=>a.id===inv.id)===i);
  if(ownedItems.length===0){showToast('Buy items first!','err');return;}

  let bodyHtml=`
    <div style="font-size:7px;color:var(--purple);margin-bottom:12px;">
      ⬆️ ${upgradeTokens} UPGRADE TOKEN(S) AVAILABLE<br>
      <span style="color:var(--dim);font-size:6px;">Each upgrade costs 0.02 SOL and adds +1.4% damage on BASE stat</span>
    </div>`;

  ownedItems.forEach(inv=>{
    const allCats=[...SHOP.weapons,...SHOP.armor,...SHOP.magic,...SHOP.boots];
    const shopItem=allCats.find(s=>s.id===inv.id);
    if(!shopItem)return;
    if(!upgrades[inv.id])upgrades[inv.id]={level:0};
    const upg=upgrades[inv.id];
    const curLevel=upg.level;
    const baseAtk=shopItem.atk||shopItem.def||shopItem.mdmg||shopItem.heals||shopItem.shield||0;
    const currentBonus=(baseAtk*(curLevel*CFG.UPGRADE_DMG_BONUS/100)).toFixed(2);
    const nextBonus=(baseAtk*((curLevel+1)*CFG.UPGRADE_DMG_BONUS/100)).toFixed(2);
    const canAfford=player.sol>=CFG.UPGRADE_COST;
    const canUpgrade=upgradeTokens>0&&canAfford;

    bodyHtml+=`
      <div class="upg-item ${canUpgrade?'available':''}">
        <div class="upg-item-left">
          <div class="upg-item-icon">${inv.icon}</div>
          <div>
            <div class="upg-item-name">${shopItem.name}</div>
            <div class="upg-item-stats">
              Base: +${baseAtk} ${shopItem.atk?'ATK':shopItem.def?'DEF':shopItem.mdmg?'MDMG':'STAT'}<br>
              Bonus now: +${currentBonus} (TIER ${curLevel})<br>
              After upg: +${nextBonus} (+1.4% base)
            </div>
          </div>
        </div>
        <div style="text-align:right">
          <div class="upg-item-level">★ TIER ${curLevel}</div>
          <button class="upg-item-btn" ${canUpgrade?'':'disabled'}
            onclick="confirmUpgrade('${inv.id}')">
            ${canAfford?`⬆ 0.02 SOL`:`NO SOL`}
          </button>
        </div>
      </div>`;
  });

  showModal('⬆️ WEAPON UPGRADES', bodyHtml, [
    {label:'✖ CLOSE',cls:'mbtn-dim',fn:closeModal}
  ]);
}

function confirmUpgrade(itemId){
  if(upgradeTokens<=0){showToast('No upgrade tokens!','err');return;}
  if(player.sol<CFG.UPGRADE_COST){showToast('Need 0.02 SOL to upgrade!','err');return;}
  if(!upgrades[itemId])upgrades[itemId]={level:0};

  player.sol-=CFG.UPGRADE_COST;
  upgrades[itemId].level++;
  upgradeTokens--;

  const allCats=[...SHOP.weapons,...SHOP.armor,...SHOP.magic,...SHOP.boots];
  const shopItem=allCats.find(s=>s.id===itemId);
  const upg=upgrades[itemId];
  const baseAtk=shopItem?shopItem.atk||shopItem.def||shopItem.mdmg||shopItem.heals||shopItem.shield||0:0;
  const newBonus=(baseAtk*(upg.level*CFG.UPGRADE_DMG_BONUS/100)).toFixed(2);

  addLog(`⬆️ ${shopItem?shopItem.name:itemId} → TIER ${upg.level} (+${newBonus} bonus)`,'upg');
  showToast(`⬆️ UPGRADED! TIER ${upg.level} +${newBonus}`,'upg');

  updateTopBar();updateButtons();updateUpgradeSection();renderInventory();

  // If more tokens remain, re-open the modal refreshed
  if(upgradeTokens>0){
    setTimeout(()=>openUpgradeModal(),200);
  }else{
    closeModal();
  }
}

// ── SKILLS ───────────────────────────────────────────
function useSkill(idx){
  if(!gameRunning)return;
  if(player.stunTimer>0&&idx!==4){
    addLog('🔒 STUNNED! Cannot attack!','dmg');
    showToast('STUNNED! '+Math.ceil(player.stunTimer/1000)+'s','err');
    return;
  }
  if(idx===0){
    const t=findNearestEnemy(1.8);
    if(t)dealDamage(player,t,player.atk);
    else addLog('No target in range','info');
  }else if(idx===1){
    if(player.mp<5){addLog('Not enough MP','info');return;}
    player.mp-=5;
    const t=findNearestEnemy(9);
    if(t)WORLD.projectiles.push({x:player.x,y:player.y,tx:t.x,ty:t.y,target:t,owner:'player',dmg:player.atk+5,type:'arrow',life:1500,spd:8});
    else addLog('No target in range','info');
  }else if(idx===2){
    const spell=SHOP.magic.find(s=>s.id===player.equipped.spell&&s.owned);
    if(!spell){addLog('No spell equipped','info');return;}
    if(player.mp<10){addLog('Not enough MP','info');return;}
    player.mp-=10;castSpell(spell);
  }else if(idx===3){
    const tx=Math.floor(player.x),ty=Math.floor(player.y);
    WORLD.traps.push({x:tx,y:ty,owner:'player',dmg:CFG.TRAP_DMG});
    player.sol=Math.max(0,player.sol-CFG.TRAP_COST_SOL);
    addLog('🪤 Trap set — stuns 5s!','info');showToast('-'+CFG.TRAP_COST_SOL+' SOL','err');updateTopBar();
  }else if(idx===4){
    if(player.mp<15){addLog('Not enough MP','info');return;}
    player.mp-=15;
    const shieldBonus=getShieldBonus();
    player.shieldAbsorb=25+shieldBonus;
    addLog('🛡️ Shield: '+(25+shieldBonus)+' absorb','heal');
    spawnFloatDmg(player,'SHIELD!','#4dcfff');
  }
  updateHUD();
}

function getShieldBonus(){
  // Extra shield from upgraded mana shield
  const shield=SHOP.magic.find(s=>s.id==='shield'&&s.owned);
  if(!shield)return 0;
  const upg=upgrades['shield'];
  if(!upg||upg.level===0)return 0;
  return Math.floor(25*(upg.level*CFG.UPGRADE_DMG_BONUS/100));
}

function castSpell(spell){
  if(spell.heals){
    const bonus=upgrades[spell.id]?Math.floor(spell.heals*(upgrades[spell.id].level*CFG.UPGRADE_DMG_BONUS/100)):0;
    const total=spell.heals+bonus;
    player.hp=Math.min(player.maxHp,player.hp+total);
    addLog('💚 Healed '+total+' HP'+(bonus>0?` (+${bonus} upg)`:''),'heal');
    spawnFloatDmg(player,'+'+total,'#39ff7e');
  }else if(spell.shield){
    const shieldBonus=getShieldBonus();
    player.shieldAbsorb=(player.shieldAbsorb||0)+spell.shield+shieldBonus;
    addLog('🔵 Magic shield! '+(spell.shield+shieldBonus)+' absorb','heal');
  }else if(spell.blink){
    const dx=(Math.random()-.5)*10,dy=(Math.random()-.5)*10;
    const nx=Math.max(.5,Math.min(CFG.MAP_W-.5,player.x+dx));
    const ny=Math.max(.5,Math.min(CFG.MAP_H-.5,player.y+dy));
    if(isPassable(nx|0,ny|0)){player.x=nx;player.y=ny;}
    addLog('🌀 Blinked!','info');
  }else if(spell.mdmg){
    const t=findNearestEnemy(7);
    if(t){
      if(spell.slow)t.slowTimer=3000;
      dealDamage(player,t,spell.mdmg);
      WORLD.projectiles.push({x:player.x,y:player.y,tx:t.x,ty:t.y,target:t,owner:'player',dmg:0,type:spell.id,life:600,spd:10});
    }else addLog('No target','info');
  }
}

function findNearestEnemy(maxDist){
  let best=null,bd=maxDist;
  const all=[...bots,(heroEntity&&heroEntity.state!=='dead'?heroEntity:null)].filter(Boolean);
  all.forEach(b=>{
    if(b.state==='dead')return;
    const d=dist(player,b);if(d<bd){bd=d;best=b;}
  });
  return best;
}

function attackTarget(targetId){
  if(!gameRunning)return;
  const target=targetId==='HERO_BOSS'?heroEntity:bots.find(b=>b.id===targetId);
  if(!target||target.state==='dead')return;
  // Calculate effective damage with upgrades
  const effDmg=Math.ceil(calcDmg(player,player.atk));
  showModal(
    '⚔️ ATTACK '+target.name+'?',
    `Target: <span class="hi">${target.name}</span><br>
     HP: <span class="hi">${Math.ceil(target.hp)}/${target.maxHp}</span><br>
     SOL: <span class="hi">${target.sol.toFixed(4)}</span><br>
     Your ATK: <span class="hi">${effDmg}${hasUpgrades()?'✨':''}</span><br>
     ${target.stunTimer>0?`<span class="warn">🔒 STUNNED ${Math.ceil(target.stunTimer/1000)}s</span><br>`:''}
     ${target.isHero?`<span class="warn">👑 HERO — Kill (LV3-5) = +0.5 SOL</span><br>`:''}
     ${!target.isHero?`Loot on kill: <span class="hi">${(target.sol*CFG.LOOT_RATE).toFixed(4)} SOL</span>`:''}`,
    [
      {label:'⚔️ ATTACK',cls:'mbtn-gold',fn:()=>{
        if(player.stunTimer>0){showToast('STUNNED!','err');closeModal();return;}
        dealDamage(player,target,player.atk);closeModal();
      }},
      {label:'🪤 TRAP',cls:'mbtn-gold',fn:()=>{useSkill(3);closeModal();}},
      {label:'✖ CANCEL',cls:'mbtn-dim',fn:closeModal},
    ]
  );
}

