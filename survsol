function buyItem(cat,itemId){
  const item=SHOP[cat].find(i=>i.id===itemId);
  if(!item||item.owned)return;
  if(player.sol<item.price){showToast('NOT ENOUGH SOL!','err');return;}
  showModal('🛒 BUY '+item.name+'?',
    `<span class="hi">${item.icon} ${item.name}</span><br>Cost: <span class="hi">${item.price} SOL</span><br>Effect: <span class="hi">${item.stat}</span>`,
    [{label:'✅ BUY',cls:'mbtn-gold',fn:()=>{confirmBuy(cat,item);closeModal();}},{label:'✖ CANCEL',cls:'mbtn-dim',fn:closeModal}]);
}
function confirmBuy(cat,item){
  player.sol-=item.price;item.owned=true;
  if(item.atk){player.atk+=item.atk;player.equipped.weapon=item.id;}
  if(item.def){player.def+=item.def;}
  if(item.spd){player.spd*=item.spd;player.equipped.boots=item.id;}
  if(item.mdmg||item.heals||item.shield||item.blink){player.equipped.spell=item.id;}
  if(cat==='armor')player.equipped.armor=item.id;
  player.inventory.push({icon:item.icon,id:item.id});
  upgrades[item.id]={level:0}; // init upgrade slot
  addLog('🛒 Bought '+item.name,'info');showToast('BOUGHT '+item.name,'suc');
  updateTopBar();updateHUD();updateButtons();renderShop();renderInventory();updateUpgradeSection();
}
function switchShopTab(tab){
