// ── WORLD ────────────────────────────────────────────
function noise(x,y){return(Math.sin(x*127.1+y*311.7)*43758.5453)%1*2-1;}
function generateMap(){
  const m=[];
  for(let y=0;y<CFG.MAP_H;y++){
    const row=[];
    for(let x=0;x<CFG.MAP_W;x++){
      const n=noise(x*.08,y*.08);
      if(n<-.3)row.push(2); else if(n<-.05)row.push(1);
      else if(n>.5)row.push(3); else if(n>.35)row.push(4);
      else row.push(0);
    }
    m.push(row);
  }
  for(let y=18;y<=22;y++)for(let x=18;x<=22;x++)m[y][x]=0;
  return m;
}
function isPassable(tx,ty){
  if(tx<0||ty<0||tx>=CFG.MAP_W||ty>=CFG.MAP_H)return false;
  return![2,3,4].includes(WORLD.map[ty][tx]);
}
