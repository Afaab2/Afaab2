<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SOL SURVIVAL — Isometric PvP Loot Game</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0b0c10;--panel:#13141a;--panel2:#1a1b24;--border:#2a2d3e;
  --green:#39ff7e;--gold:#ffd166;--red:#ff4466;--blue:#4dcfff;
  --purple:#c77dff;--orange:#ff9a3c;--white:#dde3f0;--dim:#555a6e;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);font-family:'Press Start 2P',monospace}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.12) 3px,rgba(0,0,0,.12) 4px);pointer-events:none;z-index:9000}

#app{display:grid;grid-template-columns:220px 1fr 220px;grid-template-rows:56px 1fr 48px;height:100vh;width:100vw}

/* ── TOP BAR ── */
#topbar{grid-column:1/-1;background:var(–panel);border-bottom:3px solid var(–border);display:flex;align-items:center;justify-content:space-between;padding:0 10px;gap:6px;z-index:100}
.topbar-title{font-size:10px;color:var(–gold);text-shadow:0 0 10px var(–gold);letter-spacing:2px;white-space:nowrap}
.topbar-center{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.stat-chip{font-size:7px;padding:4px 7px;border:2px solid var(–border);background:var(–panel2);color:var(–white);display:flex;align-items:center;gap:4px;white-space:nowrap}
.stat-chip .val{color:var(–gold)}
.topbar-right{display:flex;gap:5px;align-items:center;flex-shrink:0}
.tbtn{font-family:‘Press Start 2P’,monospace;font-size:7px;padding:6px 9px;border:2px solid;cursor:pointer;white-space:nowrap;transition:all .15s}
#connectBtn{border-color:var(–green);background:#001a0a;color:var(–green)}
#connectBtn:hover{background:#002a12}
#connectBtn.connected{border-color:var(–red);background:#1a0008;color:var(–red)}
#depositBtn{border-color:var(–blue);background:#001020;color:var(–blue);display:none}
#depositBtn:hover{background:#001a2a;box-shadow:0 0 12px rgba(77,207,255,.3)}
#cashoutBtn{border-color:var(–gold);background:#1a1500;color:var(–gold);display:none;animation:glow 1.5s infinite}
#cashoutBtn:hover{background:#2a2200;box-shadow:0 0 14px rgba(255,209,102,.5)}
#upgradeBtn{border-color:var(–purple);background:#0f0020;color:var(–purple);display:none;animation:upgradePulse 1s infinite}
#upgradeBtn:hover{background:#1a0035;box-shadow:0 0 14px rgba(199,125,255,.5)}
@keyframes glow{0%,100%{box-shadow:0 0 4px rgba(255,209,102,.3)}50%{box-shadow:0 0 16px rgba(255,209,102,.7)}}
@keyframes upgradePulse{0%,100%{box-shadow:0 0 4px rgba(199,125,255,.3)}50%{box-shadow:0 0 18px rgba(199,125,255,.8)}}

/* ── LEFT PANEL ── */
#leftPanel{background:var(–panel);border-right:3px solid var(–border);display:flex;flex-direction:column;overflow:hidden}
.panel-header{font-size:7px;color:var(–dim);padding:8px 12px;border-bottom:2px solid var(–border);letter-spacing:1px;display:flex;justify-content:space-between;align-items:center}
#charCard{padding:10px;border-bottom:2px solid var(–border)}
.char-sprite-wrap{width:52px;height:52px;margin:0 auto 7px;display:flex;align-items:center;justify-content:center;background:var(–panel2);border:2px solid var(–border);overflow:hidden}
#charCanvas{display:block}
.char-name{text-align:center;font-size:8px;color:var(–white);margin-bottom:3px}
.char-class{text-align:center;font-size:6px;color:var(–purple);margin-bottom:7px}
.stat-row{margin-bottom:5px}
.stat-row-label{font-size:6px;color:var(–dim);margin-bottom:2px;display:flex;justify-content:space-between}
.stat-row-label span{color:var(–white)}
.bar-track{height:5px;background:#0a0b10;border:1px solid var(–border);overflow:hidden}
.bar-fill{height:100%;transition:width .4s}
.bar-hp{background:var(–red)}.bar-mp{background:var(–blue)}.bar-xp{background:var(–purple)}
#stunBar{display:none;margin-bottom:5px;padding:4px 6px;background:#1a0a00;border:2px solid var(–orange);font-size:6px;color:var(–orange);text-align:center;animation:stunFlash .5s infinite}
@keyframes stunFlash{0%,100%{opacity:1}50%{opacity:.4}}

/* Upgrade meter in left panel */
#upgradeSection{padding:8px 10px;border-bottom:2px solid var(–border);display:none}
.upg-title{font-size:6px;color:var(–purple);margin-bottom:5px;display:flex;justify-content:space-between;align-items:center}
.upg-kills-bar{height:5px;background:#0a0b10;border:1px solid var(–border);overflow:hidden;margin-bottom:5px}
.upg-kills-fill{height:100%;background:var(–purple);transition:width .4s}
.upg-info{font-size:5px;color:var(–dim);line-height:1.8}
.upg-badge{font-size:6px;color:var(–gold);padding:2px 5px;border:1px solid var(–gold);display:inline-block;margin-top:4px}

#inventory{flex:1;overflow-y:auto;padding:7px}
#inventory::-webkit-scrollbar{width:3px}
#inventory::-webkit-scrollbar-thumb{background:var(–border)}
.inv-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px}
.inv-slot{aspect-ratio:1;background:var(–panel2);border:2px solid var(–border);display:flex;align-items:center;justify-content:center;font-size:13px;position:relative}
.inv-slot.equipped{border-color:var(–green)}
.inv-slot .upg-star{position:absolute;bottom:0;right:0;font-size:5px;color:var(–gold);background:rgba(0,0,0,.7);padding:1px 2px}

/* ── GAME AREA ── */
#gameArea{position:relative;overflow:hidden;background:var(–bg)}
#gameCanvas{display:block;width:100%;height:100%}
#minimap{position:absolute;bottom:10px;right:10px;width:90px;height:90px;border:2px solid var(–border);background:rgba(10,11,16,.85);overflow:hidden}
#minimapCanvas{display:block;width:100%;height:100%}
#combatLog{position:absolute;bottom:10px;left:10px;width:210px;max-height:100px;overflow:hidden;display:flex;flex-direction:column-reverse;gap:2px;pointer-events:none}
.clog-entry{font-size:6px;padding:3px 6px;background:rgba(10,11,16,.85);border-left:2px solid var(–dim);animation:fadeLog 6s forwards;line-height:1.6}
@keyframes fadeLog{0%,70%{opacity:1}100%{opacity:0}}
.clog-entry.dmg{border-color:var(–red);color:var(–red)}
.clog-entry.loot{border-color:var(–gold);color:var(–gold)}
.clog-entry.info{border-color:var(–blue);color:var(–blue)}
.clog-entry.heal{border-color:var(–green);color:var(–green)}
.clog-entry.hero{border-color:var(–purple);color:var(–purple)}
.clog-entry.upg{border-color:var(–purple);color:var(–purple)}

#skillBar{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);display:flex;gap:5px}
.skill-slot{width:38px;height:38px;background:rgba(19,20,26,.9);border:2px solid var(–border);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;font-size:16px;position:relative;transition:border-color .15s}
.skill-slot:hover{border-color:var(–gold)}
.skill-slot .sk-key{position:absolute;top:1px;left:2px;font-size:5px;color:var(–dim)}
.skill-slot.stunned{opacity:.3;pointer-events:none}

#heroBanner{position:absolute;top:60px;left:50%;transform:translateX(-50%);background:rgba(199,125,255,.15);border:3px solid var(–purple);padding:8px 20px;font-size:8px;color:var(–purple);text-shadow:0 0 10px var(–purple);display:none;white-space:nowrap;z-index:200;animation:heroPulse 1s infinite}
@keyframes heroPulse{0%,100%{border-color:var(–purple)}50%{border-color:#ff9a3c}}
#auraBanner{position:absolute;top:10px;left:50%;transform:translateX(-50%);background:rgba(255,100,66,.15);border:2px solid var(–red);padding:5px 14px;font-size:7px;color:var(–red);display:none;white-space:nowrap;z-index:200;animation:auraFlash .4s infinite}
@keyframes auraFlash{0%,100%{opacity:1}50%{opacity:.4}}
#upgradeBanner{position:absolute;top:10px;left:50%;transform:translateX(-50%);background:rgba(199,125,255,.2);border:3px solid var(–purple);padding:8px 18px;font-size:8px;color:var(–purple);display:none;white-space:nowrap;z-index:200;animation:heroPulse 1s infinite}

/* ── RIGHT PANEL ── */
#rightPanel{background:var(–panel);border-left:3px solid var(–border);display:flex;flex-direction:column;overflow:hidden}
#playersList{flex:1;overflow-y:auto;padding:6px}
#playersList::-webkit-scrollbar{width:3px}
#playersList::-webkit-scrollbar-thumb{background:var(–border)}
.player-row{padding:6px 8px;border:2px solid var(–border);margin-bottom:4px;cursor:pointer;background:var(–panel2);transition:border-color .15s;position:relative}
.player-row:hover{border-color:var(–red)}
.player-row.self{border-color:var(–green);cursor:default}
.player-row.hero-row{border-color:var(–purple);background:#140a1e}
.pr-name{font-size:6px;color:var(–white);margin-bottom:3px;display:flex;justify-content:space-between}
.pr-lvl{color:var(–gold)}
.pr-hp{height:3px;background:var(–panel);margin-bottom:2px}
.pr-hp-fill{height:100%;background:var(–red);transition:width .3s}
.pr-sol{font-size:5px;color:var(–gold)}
.pr-badge{font-size:9px;position:absolute;right:5px;top:50%;transform:translateY(-50%)}
.pr-stun{font-size:5px;color:var(–orange);margin-top:2px}

#shop{border-top:2px solid var(–border)}
.shop-tabs{display:flex;border-bottom:2px solid var(–border)}
.shop-tab{flex:1;font-family:‘Press Start 2P’,monospace;font-size:6px;padding:6px 2px;border:none;background:var(–panel);color:var(–dim);cursor:pointer;border-right:1px solid var(–border);transition:all .15s}
.shop-tab:last-child{border-right:none}
.shop-tab.active{background:var(–panel2);color:var(–gold)}
.shop-items{padding:6px;display:grid;grid-template-columns:1fr 1fr;gap:4px;max-height:160px;overflow-y:auto}
.shop-items::-webkit-scrollbar{width:3px}
.shop-items::-webkit-scrollbar-thumb{background:var(–border)}
.shop-item{padding:6px 5px;border:2px solid var(–border);background:var(–panel2);cursor:pointer;transition:all .15s;text-align:center}
.shop-item:hover{border-color:var(–gold);background:#1e1c0f}
.si-icon{font-size:16px;display:block;margin-bottom:3px}
.si-name{font-size:5px;color:var(–white);margin-bottom:2px;line-height:1.4}
.si-price{font-size:5px;color:var(–gold)}
.si-stat{font-size:5px;color:var(–green);margin-top:2px}
.shop-item.owned{border-color:var(–green);opacity:.6;cursor:default}

/* ── BOTTOM BAR ── */
#bottomBar{grid-column:1/-1;background:var(–panel);border-top:3px solid var(–border);display:flex;align-items:center;padding:0 12px;gap:10px;font-size:6px;color:var(–dim)}
.bb-dot{width:6px;height:6px;background:var(–green);display:inline-block;margin-right:4px;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.bb-sep{width:1px;height:20px;background:var(–border)}

/* ── MODAL ── */
#modal{position:fixed;inset:0;background:rgba(0,0,0,.88);display:none;align-items:center;justify-content:center;z-index:8000}
#modal.open{display:flex}
.modal-box{background:var(–panel);border:3px solid var(–gold);padding:22px;max-width:420px;width:92%;position:relative;max-height:90vh;overflow-y:auto}
.modal-box::before{content:’’;position:absolute;width:8px;height:8px;background:var(–gold);top:-4px;left:-4px}
.modal-box::after{content:’’;position:absolute;width:8px;height:8px;background:var(–gold);bottom:-4px;right:-4px}
.modal-title{font-size:10px;color:var(–gold);text-shadow:0 0 10px var(–gold);margin-bottom:14px;line-height:1.6}
.modal-body{font-size:8px;color:var(–white);line-height:2.2;margin-bottom:16px}
.modal-body .hi{color:var(–green)}
.modal-body .warn{color:var(–orange)}
.modal-body .purple{color:var(–purple)}
.modal-actions{display:flex;gap:8px;flex-wrap:wrap}
.mbtn{font-family:‘Press Start 2P’,monospace;font-size:7px;padding:9px 14px;border:2px solid;cursor:pointer;transition:all .1s}
.mbtn:active{transform:translate(2px,2px)}
.mbtn-gold{background:#1a1500;color:var(–gold);border-color:var(–gold)}
.mbtn-gold:hover{background:#2a2200;box-shadow:0 0 12px rgba(255,209,102,.3)}
.mbtn-green{background:#001a08;color:var(–green);border-color:var(–green)}
.mbtn-green:hover{background:#002a12}
.mbtn-blue{background:#001020;color:var(–blue);border-color:var(–blue)}
.mbtn-blue:hover{background:#001830}
.mbtn-purple{background:#0f0020;color:var(–purple);border-color:var(–purple)}
.mbtn-purple:hover{background:#1a0033}
.mbtn-dim{background:var(–panel2);color:var(–dim);border-color:var(–border)}

/* Deposit amount input */
.dep-input-wrap{position:relative;margin:10px 0}
.dep-input{width:100%;background:#080810;border:3px solid var(–border);color:var(–gold);font-family:‘Press Start 2P’,monospace;font-size:10px;padding:10px 46px 10px 12px;outline:none;transition:border-color .2s}
.dep-input:focus{border-color:var(–blue);box-shadow:0 0 8px rgba(77,207,255,.2)}
.dep-currency{position:absolute;right:10px;top:50%;transform:translateY(-50%);font-size:8px;color:var(–gold)}
.dep-presets{display:flex;gap:6px;flex-wrap:wrap;margin:6px 0}
.dep-preset{font-family:‘Press Start 2P’,monospace;font-size:6px;padding:6px 8px;background:#0a0a14;border:2px solid #2a2a4a;color:#8888aa;cursor:pointer;transition:all .1s}
.dep-preset:hover{border-color:var(–blue);color:var(–blue)}

/* Upgrade modal items */
.upg-item{display:flex;align-items:center;justify-content:space-between;padding:8px;border:2px solid var(–border);margin-bottom:6px;background:var(–panel2)}
.upg-item.available{border-color:var(–purple)}
.upg-item-left{display:flex;align-items:center;gap:8px}
.upg-item-icon{font-size:20px}
.upg-item-name{font-size:6px;color:var(–white);line-height:1.8}
.upg-item-stats{font-size:5px;color:var(–green);margin-top:2px}
.upg-item-btn{font-family:‘Press Start 2P’,monospace;font-size:6px;padding:6px 8px;border:2px solid var(–purple);background:#0f0020;color:var(–purple);cursor:pointer;white-space:nowrap;transition:all .1s}
.upg-item-btn:hover{background:#1a0033;box-shadow:0 0 10px rgba(199,125,255,.4)}
.upg-item-btn:disabled{opacity:.3;cursor:not-allowed}
.upg-item-level{font-size:5px;color:var(–gold);text-align:right}

/* ── TOAST ── */
#toast{position:fixed;top:66px;left:50%;transform:translateX(-50%) translateY(-16px);background:var(–panel);border:2px solid var(–gold);padding:8px 14px;font-size:7px;color:var(–gold);z-index:9999;opacity:0;transition:all .3s;white-space:nowrap;pointer-events:none}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#toast.err{border-color:var(–red);color:var(–red)}
#toast.suc{border-color:var(–green);color:var(–green)}
#toast.hero{border-color:var(–purple);color:var(–purple)}
#toast.upg{border-color:var(–purple);color:var(–purple)}

/* ── FLOAT DAMAGE ── */
.dmg-float{position:absolute;font-size:7px;font-family:‘Press Start 2P’,monospace;pointer-events:none;z-index:500;animation:floatUp 1.2s forwards}
@keyframes floatUp{0%{opacity:1;transform:translateY(0)}100%{opacity:0;transform:translateY(-44px)}}

/* ── WALLET PICKER ── */
.wallet-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.wallet-card{padding:12px 8px;border:2px solid var(–border);background:var(–panel2);cursor:pointer;text-align:center;transition:all .15s}
.wallet-card:hover{transform:translateY(-2px)}
.wallet-card-icon{font-size:24px;margin-bottom:5px}
.wallet-card-name{font-size:7px;margin-bottom:3px}
.wallet-card-status{font-size:5px}

/* ── LOBBY ── */
#lobbyScreen{position:fixed;inset:0;background:var(–bg);z-index:7000;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px}
#lobbyScreen.hidden{display:none}
.lobby-title{font-size:clamp(14px,3vw,22px);color:var(–gold);text-shadow:0 0 20px var(–gold);text-align:center;line-height:2}
.lobby-features{display:grid;grid-template-columns:1fr 1fr;gap:7px;max-width:440px;width:100%}
.lf-item{padding:8px;border:2px solid var(–border);background:var(–panel);font-size:7px;color:var(–white);display:flex;gap:7px;align-items:center;line-height:1.6}
.lfi{font-size:18px;flex-shrink:0}
</style>

</head>
<body>

<!-- LOBBY -->

<div id="lobbyScreen">
  <div style="font-size:50px;line-height:1">⚔️🗺️💰</div>
  <div class="lobby-title">SOL SURVIVAL<br><span style="font-size:.5em;color:var(--purple)">ISOMETRIC PvP LOOT ARENA</span></div>
  <div style="font-size:8px;color:var(--dim);text-align:center;line-height:2.2">Connect Phantom · OKX · Binance · Jupiter · Deposit SOL · Fight · Upgrade · Survive</div>
  <div class="lobby-features">
    <div class="lf-item"><span class="lfi">💳</span><span>Deposit 0.001–10 SOL to play</span></div>
    <div class="lf-item"><span class="lfi">⚔️</span><span>Every 3 kills = weapon upgrade available</span></div>
    <div class="lf-item"><span class="lfi">⬆️</span><span>Upgrades add +1.4% dmg per tier (compounding)</span></div>
    <div class="lf-item"><span class="lfi">👑</span><span>Hero Boss spawns every 5 lvls — 0.5 SOL reward</span></div>
    <div class="lf-item"><span class="lfi">🪤</span><span>Traps stun enemies 5s — they can't attack</span></div>
    <div class="lf-item"><span class="lfi">💸</span><span>Cashout your SOL winnings anytime</span></div>
  </div>
  <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center">
    <button class="mbtn mbtn-gold" onclick="openWalletPicker()">▶ CONNECT WALLET</button>
    <button class="mbtn mbtn-dim" onclick="enterDemo()">▶ DEMO MODE</button>
  </div>
  <div style="font-size:6px;color:var(--dim);text-align:center;line-height:2.2">⚠ MAINNET — Real SOL transactions</div>
</div>

<!-- MAIN APP -->

<div id="app">
  <div id="topbar">
    <div class="topbar-title">⚔ SOL SURVIVAL</div>
    <div class="topbar-center">
      <div class="stat-chip">👤 <span id="tbName" class="val">---</span></div>
      <div class="stat-chip">💰 <span id="tbSol" class="val">0.000</span> SOL</div>
      <div class="stat-chip">⭐ LV <span id="tbLevel" class="val">1</span></div>
      <div class="stat-chip">💀 <span id="tbKills" class="val">0</span> KILLS</div>
      <div class="stat-chip">🌍 <span id="tbOnline" class="val">1</span> ONLINE</div>
    </div>
    <div class="topbar-right">
      <button class="tbtn" id="upgradeBtn" onclick="openUpgradeModal()">⬆️ UPGRADE!</button>
      <button class="tbtn" id="cashoutBtn" onclick="openCashout()">💸 CASHOUT</button>
      <button class="tbtn" id="depositBtn" onclick="openDeposit()">💳 DEPOSIT</button>
      <button class="tbtn" id="connectBtn" onclick="toggleConnect()">▶ CONNECT WALLET</button>
    </div>
  </div>

  <!-- LEFT -->

  <div id="leftPanel">
    <div class="panel-header">▶ CHARACTER</div>
    <div id="charCard">
      <div class="char-sprite-wrap"><canvas id="charCanvas" width="48" height="48"></canvas></div>
      <div class="char-name" id="charName">HERO</div>
      <div class="char-class" id="charClass">WANDERER LV.1</div>
      <div id="stunBar">🔒 STUNNED! <span id="stunCountdown">5</span>s</div>
      <div class="stat-row">
        <div class="stat-row-label">HP <span id="hpVal">100/100</span></div>
        <div class="bar-track"><div class="bar-fill bar-hp" id="hpBar" style="width:100%"></div></div>
      </div>
      <div class="stat-row">
        <div class="stat-row-label">MP <span id="mpVal">50/50</span></div>
        <div class="bar-track"><div class="bar-fill bar-mp" id="mpBar" style="width:100%"></div></div>
      </div>
      <div class="stat-row">
        <div class="stat-row-label">XP <span id="xpVal">0/100</span></div>
        <div class="bar-track"><div class="bar-fill bar-xp" id="xpBar" style="width:0%"></div></div>
      </div>
    </div>
    <!-- Upgrade progress section -->
    <div id="upgradeSection">
      <div class="upg-title">⬆ UPGRADE METER <span id="upgTierBadge" class="upg-badge">TIER 0</span></div>
      <div class="upg-kills-bar"><div class="upg-kills-fill" id="upgKillsFill" style="width:0%"></div></div>
      <div class="upg-info" id="upgInfo">0 kills → 3 kills for first upgrade</div>
    </div>
    <div class="panel-header">▶ INVENTORY</div>
    <div id="inventory"><div class="inv-grid" id="invGrid"></div></div>
  </div>

  <!-- GAME -->

  <div id="gameArea">
    <canvas id="gameCanvas"></canvas>
    <div id="minimap"><canvas id="minimapCanvas" width="90" height="90"></canvas></div>
    <div id="combatLog"></div>
    <div id="heroBanner">👑 HERO BOSS SPAWNED! SLAY IT FOR 0.5 SOL!</div>
    <div id="auraBanner">⚡ HERO AURA — TAKING DAMAGE!</div>
