// ── MULTI-WALLET SYSTEM ──────────────────────────────
// Supported: Phantom, OKX, Binance Web3, Jupiter (Unified Wallet)
let activeWalletType = null; // 'phantom'|'okx'|'binance'|'jupiter'
let activeProvider = null;

const WALLETS = [
  {
    id: 'phantom',
    name: 'PHANTOM',
    icon: '👻',
    color: '#ab9ff2',
    installUrl: 'https://phantom.app/',
    detect: () => {
      const p = window.phantom?.solana;
      return (p && p.isPhantom) ? p : null;
    },
    connect: async (p) => {
      const r = await p.connect();
      return r.publicKey.toString();
    },
    disconnect: async (p) => p.disconnect().catch(()=>{}),
  },
  {
    id: 'okx',
    name: 'OKX WALLET',
    icon: '⬛',
    color: '#00d2ff',
    installUrl: 'https://www.okx.com/web3',
    detect: () => {
      // OKX injects window.okxwallet or window.okxwallet.solana
      const okx = window.okxwallet?.solana || window.okxwallet;
      return okx ? okx : null;
    },
    connect: async (p) => {
      // OKX solana provider
      const r = await p.connect();
      return (r.publicKey || r).toString();
    },
    disconnect: async (p) => p.disconnect ? p.disconnect().catch(()=>{}) : null,
  },
  {
    id: 'binance',
    name: 'BINANCE',
    icon: '🟡',
    color: '#f0b90b',
    installUrl: 'https://www.bnbchain.org/en/binance-wallet',
    detect: () => {
      // Binance Web3 wallet injects window.BinanceChain or window.binance
      // For Solana it may expose window.binanceSolana
      return window.binanceSolana || window.BinanceChain?.solana || null;
    },
    connect: async (p) => {
      const r = await p.connect();
      return (r.publicKey || r.address || r).toString();
    },
    disconnect: async (p) => p.disconnect ? p.disconnect().catch(()=>{}) : null,
  },
  {
    id: 'jupiter',
    name: 'JUPITER',
    icon: '🪐',
    color: '#c8a2e8',
    installUrl: 'https://jup.ag/',
    detect: () => {
      // Jupiter Unified Wallet wraps Phantom/other wallets. It exposes
      // window.jupiter or falls back to the underlying wallet.
      return window.jupiter?.solana || window.jupiterWallet || null;
    },
    connect: async (p) => {
      const r = await p.connect();
      return (r.publicKey || r).toString();
    },
    disconnect: async (p) => p.disconnect ? p.disconnect().catch(()=>{}) : null,
  },
];

function toggleConnect(){
  if(walletConnected) disconnectWallet();
  else openWalletPicker();
}

function openWalletPicker(){
  // Build wallet selection UI
  let body = `<div style="font-size:7px;color:var(--dim);margin-bottom:14px;line-height:2">
    Choose your Solana wallet to connect.<br>
    <span style="color:var(--orange);font-size:6px;">⚠ If not installed, you'll be redirected to download.</span>
  </div>`;

  body += `<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;">`;
  WALLETS.forEach(w => {
    const detected = w.detect();
    const statusColor = detected ? 'var(--green)' : 'var(--dim)';
    const statusTxt = detected ? 'DETECTED' : 'NOT FOUND';
    body += `
      <div onclick="connectWallet('${w.id}')" style="
        padding:12px 8px;border:2px solid ${detected?w.color:'var(--border)'};
        background:${detected?'rgba(0,0,0,.4)':'var(--panel2)'};
        cursor:pointer;text-align:center;transition:all .15s;
        ${detected?`box-shadow:0 0 10px ${w.color}33`:''}"
        onmouseover="this.style.borderColor='${w.color}';this.style.background='rgba(0,0,0,.6)'"
        onmouseout="this.style.borderColor='${detected?w.color:'var(--border)'}';this.style.background='${detected?'rgba(0,0,0,.4)':'var(--panel2)'}'"
      >
        <div style="font-size:24px;margin-bottom:6px;">${w.icon}</div>
        <div style="font-size:7px;color:${w.color};margin-bottom:4px;">${w.name}</div>
        <div style="font-size:5px;color:${statusColor};">${statusTxt}</div>
      </div>`;
  });
  body += `</div>`;

  showModal('🔗 CONNECT WALLET', body, [
    {label:'▶ DEMO MODE',cls:'mbtn-dim',fn:()=>{closeModal();enterDemo();}},
    {label:'✖ CANCEL',cls:'mbtn-dim',fn:closeModal},
  ]);
}

async function connectWallet(walletId){
  closeModal();
  const def = WALLETS.find(w=>w.id===walletId);
  if(!def) return;

  const provider = def.detect();
  if(!provider){
    showToast(def.name+' not found — opening install page','err');
    window.open(def.installUrl,'_blank');
    return;
  }

  try{
    showToast('Connecting '+def.name+'...','');
    const addr = await def.connect(provider);
    walletAddress = addr;
    walletConnected = true;
    activeWalletType = walletId;
    activeProvider = provider;

    await fetchBalance();
    player.name = walletAddress.slice(0,4).toUpperCase();

    document.getElementById('connectBtn').textContent = def.icon+' DISCONNECT';
    document.getElementById('connectBtn').className = 'tbtn connected';
    document.getElementById('bbAddr').textContent = walletAddress.slice(0,8)+'...';
    document.getElementById('bbStatus').textContent = def.name+' · MAINNET';

    updateButtons();
    if(!gameRunning) enterGame();
    else showToast(def.name+' connected!','suc');

  }catch(e){
    showToast('Connection failed: '+(e.message||'rejected'),'err');
  }
}

async function disconnectWallet(){
  if(activeProvider && activeWalletType){
    const def = WALLETS.find(w=>w.id===activeWalletType);
    if(def) await def.disconnect(activeProvider);
  }
  walletConnected=false; walletAddress=null;
  activeWalletType=null; activeProvider=null;
  document.getElementById('connectBtn').textContent='▶ CONNECT WALLET';
  document.getElementById('connectBtn').className='tbtn';
  document.getElementById('bbAddr').textContent='NOT CONNECTED';
  document.getElementById('bbStatus').textContent='AWAITING WALLET';
  document.getElementById('depositBtn').style.display='none';
  showToast('Disconnected','');
  updateButtons();
}

async function fetchBalance(){
  if(!walletAddress)return;
  try{
    const r=await fetch('https://api.mainnet-beta.solana.com',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({jsonrpc:'2.0',id:1,method:'getBalance',params:[walletAddress,{commitment:'confirmed'}]})
    });
    const d=await r.json();walletBalance=(d.result?.value||0)/1e9;
  }catch(e){}
}

// For deposit: use the activeProvider to sign transactions
function getProvider(){
  return activeProvider;
}
function enterDemo(){
  player.sol=.1;player.name='DEMO';
  document.getElementById('bbAddr').textContent='DEMO MODE';
  document.getElementById('bbStatus').textContent='NO WALLET';
  document.getElementById('connectBtn').textContent='▶ CONNECT WALLET';
  enterGame();
}
// Alias for backward compat
function connectAndEnter(){ openWalletPicker(); }
function enterGame(){
  document.getElementById('lobbyScreen').classList.add('hidden');
  bots=Array.from({length:CFG.BOT_COUNT},(_,i)=>createBot(i));
  gameRunning=true;
  drawCharSprite();renderShop();renderInventory();updateHUD();updateTopBar();updateButtons();updateUpgradeSection();
  setInterval(()=>{updatePlayersList();updateTopBar();updateButtons();updateUpgradeSection();},1500);
  requestAnimationFrame(ts=>{lastFrame=ts;renderFrame(ts);});
  addLog('⚔️ ENTERED THE ARENA','info');
  addLog('💡 WASD=move Q/W/E/R/F=skills','info');
  addLog('⬆️ 3 kills = upgrade available!','upg');
  addLog('💳 Use DEPOSIT to add SOL','info');
  showToast('WELCOME TO SOL SURVIVAL','suc');
}

// ── INPUT ────────────────────────────────────────────
document.addEventListener('keydown',e=>{
  keys[e.key.toLowerCase()]=true;
  if(e.key==='q')useSkill(0);
  if(e.key==='e')useSkill(2);
  if(e.key==='r')useSkill(3);
  if(e.key==='f')useSkill(4);
  if(e.key==='Escape')closeModal();
});
document.addEventListener('keyup',e=>keys[e.key.toLowerCase()]=false);

canvas.addEventListener('click',e=>{
  if(!gameRunning)return;
  const rect=canvas.getBoundingClientRect();
  const mx=e.clientX-rect.left,my=e.clientY-rect.top;
  let best=null,bd=50;
  const allT=[...bots,(heroEntity&&heroEntity.state!=='dead'?heroEntity:null)].filter(Boolean);
  allT.forEach(b=>{
    if(b.state==='dead')return;
    const pp=worldToIso(b.x,b.y);
    const sx=pp.x-camera.x+canvas.width/2,sy=pp.y-camera.y+canvas.height/2;
    const d=Math.sqrt((mx-sx)**2+(my-sy)**2);
    if(d<bd){bd=d;best=b;}
  });
  if(best)attackTarget(best.id);
});

