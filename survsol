// ── RENDERER ─────────────────────────────────────────
const canvas=document.getElementById('gameCanvas');
const ctx=canvas.getContext('2d');
const mmCanvas=document.getElementById('minimapCanvas');
const mmCtx=mmCanvas.getContext('2d');

function worldToIso(wx,wy){return{x:(wx-wy)*CFG.ISO_TW/2,y:(wx+wy)*CFG.ISO_TH/2};}
function resizeCanvas(){canvas.width=canvas.offsetWidth;canvas.height=canvas.offsetHeight;}

const TILE_TOP={0:'#224429',1:'#2a5236',2:'#0f2d40',3:'#4d4d4d',4:'#225020'};

function drawTile(gx,gy,type){
  const{x:sx,y:sy}=worldToIso(gx,gy);
  const cx=sx-camera.x+canvas.width/2,cy=sy-camera.y+canvas.height/2;
  const w=CFG.ISO_TW,h=CFG.ISO_TH,half=h/2;
  if(cx<-w||cx>canvas.width+w||cy<-h*3||cy>canvas.height+h*3)return;
  ctx.beginPath();ctx.moveTo(cx,cy-half);ctx.lineTo(cx+w/2,cy);ctx.lineTo(cx,cy+half);ctx.lineTo(cx-w/2,cy);ctx.closePath();
  ctx.fillStyle=TILE_TOP[type]||TILE_TOP[0];ctx.fill();
  if(type===3){
    ctx.beginPath();ctx.moveTo(cx-w/2,cy);ctx.lineTo(cx,cy+half);ctx.lineTo(cx,cy+half+8);ctx.lineTo(cx-w/2,cy+8);ctx.closePath();ctx.fillStyle='#333';ctx.fill();
    ctx.beginPath();ctx.moveTo(cx,cy+half);ctx.lineTo(cx+w/2,cy);ctx.lineTo(cx+w/2,cy+8);ctx.lineTo(cx,cy+half+8);ctx.closePath();ctx.fillStyle='#2a2a2a';ctx.fill();
  }else if(type===4){
    ctx.beginPath();ctx.arc(cx,cy-10,10,0,Math.PI*2);ctx.fillStyle='#1a4a18';ctx.fill();
    ctx.beginPath();ctx.arc(cx-2,cy-15,7,0,Math.PI*2);ctx.fillStyle='#236622';ctx.fill();
  }else if(type===2){
    ctx.beginPath();ctx.moveTo(cx,cy-half*.5);ctx.lineTo(cx+w*.3,cy-.5);ctx.lineTo(cx,cy+half*.3);ctx.lineTo(cx-w*.3,cy-.5);ctx.closePath();
    ctx.fillStyle='rgba(77,207,255,.12)';ctx.fill();
  }
  ctx.beginPath();ctx.moveTo(cx,cy-half);ctx.lineTo(cx+w/2,cy);ctx.lineTo(cx,cy+half);ctx.lineTo(cx-w/2,cy);ctx.closePath();
  ctx.strokeStyle='rgba(0,0,0,.2)';ctx.lineWidth=.5;ctx.stroke();
}

function drawEntity(e,isPlayer){
  if(e.state==='dead')return;
  const{x:sx,y:sy}=worldToIso(e.x,e.y);
  const cx=sx-camera.x+canvas.width/2,cy=sy-camera.y+canvas.height/2;
  if(cx<-80||cx>canvas.width+80||cy<-80||cy>canvas.height+80)return;
  const col=e.color||'#39ff7e',sz=e.isHero?13:(isPlayer?9:8);
  const stunned=e.stunTimer>0;

  // Check if player has upgrades (sparkle effect)
  const playerHasUpg=isPlayer&&hasUpgrades();

  ctx.beginPath();ctx.ellipse(cx,cy+4,sz*.8,sz*.3,0,0,Math.PI*2);ctx.fillStyle='rgba(0,0,0,.4)';ctx.fill();
  if(e.isHero){
    ctx.beginPath();ctx.arc(cx,cy-sz*.5,sz+8,0,Math.PI*2);
    const g=ctx.createRadialGradient(cx,cy-sz*.5,0,cx,cy-sz*.5,sz+8);
    g.addColorStop(0,'rgba(199,125,255,.3)');g.addColorStop(1,'rgba(199,125,255,0)');
    ctx.fillStyle=g;ctx.fill();
  }
  if(playerHasUpg){
    // Gold upgrade aura
    ctx.beginPath();ctx.arc(cx,cy-sz*.5,sz+6,0,Math.PI*2);
    ctx.strokeStyle='rgba(255,209,102,.4)';ctx.lineWidth=2;ctx.stroke();
  }
  ctx.fillStyle=isPlayer?'#2a5a3a':e.isHero?'#3a0060':'#3a2a2a';
  ctx.fillRect(cx-sz*.4,cy,sz*.35,sz*.65);ctx.fillRect(cx+sz*.05,cy,sz*.35,sz*.65);
  ctx.fillStyle=stunned?'#ff6600':col;ctx.fillRect(cx-sz*.5,cy-sz*.9,sz,sz*.9);
  ctx.fillStyle=e.isHero?'#e0b0ff':'#ffe0b2';ctx.fillRect(cx-sz*.35,cy-sz*1.7,sz*.7,sz*.8);
  ctx.fillStyle='#000';ctx.fillRect(cx-sz*.2,cy-sz*1.45,2,2);ctx.fillRect(cx+sz*.1,cy-sz*1.45,2,2);
  if(e.isHero){ctx.font='14px serif';ctx.textAlign='center';ctx.fillText('👑',cx,cy-sz*1.9);}
  if(stunned){ctx.font='12px serif';ctx.textAlign='center';ctx.fillText('💫',cx,cy-sz*2-2);}
  if((e.shieldAbsorb||0)>0){
    ctx.beginPath();ctx.arc(cx,cy-sz*.5,sz+5,0,Math.PI*2);ctx.strokeStyle='rgba(77,207,255,.7)';ctx.lineWidth=2;ctx.stroke();
  }
  const bw=e.isHero?40:28,bh=3;
  ctx.fillStyle='#1a1a1a';ctx.fillRect(cx-bw/2,cy-sz*2-9,bw,bh);
  ctx.fillStyle=e.isHero?'#c77dff':e.hp/e.maxHp>.5?'#39ff7e':e.hp/e.maxHp>.25?'#ffd166':'#ff4466';
  ctx.fillRect(cx-bw/2,cy-sz*2-9,bw*(Math.max(0,e.hp)/e.maxHp),bh);
  ctx.font='5px "Press Start 2P"';ctx.textAlign='center';
  ctx.fillStyle='rgba(0,0,0,.7)';ctx.fillRect(cx-22,cy-sz*2-22,44,11);
  ctx.fillStyle=isPlayer?'#39ff7e':e.isHero?'#c77dff':col;
  ctx.fillText(e.isHero?'HERO BOSS':e.name.slice(0,6),cx,cy-sz*2-14);
  if(!e.isHero&&e.sol>0){ctx.fillStyle='rgba(255,209,102,.8)';ctx.font='5px "Press Start 2P"';ctx.fillText(e.sol.toFixed(3)+'◎',cx,cy-sz*2-6);}
}

function drawTrap(trap){
  const{x:sx,y:sy}=worldToIso(trap.x+.5,trap.y+.5);
  const cx=sx-camera.x+canvas.width/2,cy=sy-camera.y+canvas.height/2;
  ctx.font='14px serif';ctx.textAlign='center';ctx.fillText('🪤',cx,cy+4);
}
function drawProjectile(proj){
  const{x:sx,y:sy}=worldToIso(proj.x,proj.y);
  const cx=sx-camera.x+canvas.width/2,cy=sy-camera.y+canvas.height/2;
  const icons={arrow:'➤',fireball:'🔥',frost:'❄️',heal:'💚',blink:'🌀'};
  ctx.font='11px serif';ctx.textAlign='center';ctx.fillText(icons[proj.type]||'•',cx,cy);
}
function drawMinimap(){
  mmCtx.clearRect(0,0,90,90);const sc=90/CFG.MAP_W;
  for(let y=0;y<CFG.MAP_H;y++)for(let x=0;x<CFG.MAP_W;x++){
    const t=WORLD.map[y][x];
    mmCtx.fillStyle=t===2?'#0d2233':t===3?'#555':t===4?'#1a4a18':'#1a3320';
    mmCtx.fillRect(x*sc,y*sc,sc+.5,sc+.5);
  }
  WORLD.traps.forEach(t=>{mmCtx.fillStyle='#ffd166';mmCtx.fillRect(t.x*sc,t.y*sc,2,2);});
  if(heroEntity&&heroEntity.state!=='dead'){mmCtx.fillStyle='#c77dff';mmCtx.fillRect(heroEntity.x*sc-3,heroEntity.y*sc-3,6,6);}
  bots.forEach(b=>{if(b.state!=='dead'){mmCtx.fillStyle=b.color;mmCtx.fillRect(b.x*sc-1,b.y*sc-1,3,3);}});
  mmCtx.fillStyle='#39ff7e';mmCtx.fillRect(player.x*sc-2,player.y*sc-2,4,4);
}

// ── GAME LOOP ─────────────────────────────────────────
function renderFrame(ts){
  const dt=Math.min(ts-lastFrame,100);lastFrame=ts;
  if(!gameRunning){requestAnimationFrame(renderFrame);return;}
  resizeCanvas();ctx.clearRect(0,0,canvas.width,canvas.height);
  const pp=worldToIso(player.x,player.y);
  camera.x+=(pp.x-camera.x)*.1;camera.y+=(pp.y-camera.y)*.1;
  for(let y=0;y<CFG.MAP_H;y++)for(let x=0;x<CFG.MAP_W;x++)drawTile(x,y,WORLD.map[y][x]);
  WORLD.traps.forEach(drawTrap);
  const all=[player,...bots.filter(b=>b.state!=='dead')];
  if(heroEntity&&heroEntity.state!=='dead')all.push(heroEntity);
  all.sort((a,b)=>(a.x+a.y)-(b.x+b.y));
  all.forEach(e=>drawEntity(e,e===player));
  updateProjectiles(dt);WORLD.projectiles.forEach(drawProjectile);
  handleMovement(dt);tickBots(dt);tickHeroAura(dt);
  player.hp=Math.min(player.maxHp,player.hp+CFG.REGEN_HP*dt/1000);
  player.mp=Math.min(player.maxMp,player.mp+CFG.REGEN_MP*dt/1000);
  if(player.stunTimer>0){
    player.stunTimer=Math.max(0,player.stunTimer-dt);
    document.getElementById('stunBar').style.display='block';
    document.getElementById('stunCountdown').textContent=Math.ceil(player.stunTimer/1000);
    document.querySelectorAll('.skill-slot').forEach((s,i)=>{if(i!==4)s.classList.add('stunned');});
    if(player.stunTimer===0){
      document.getElementById('stunBar').style.display='none';
      document.querySelectorAll('.skill-slot').forEach(s=>s.classList.remove('stunned'));
      addLog('🔓 STUN ENDED!','heal');
    }
  }
  if(player.slowTimer>0)player.slowTimer-=dt;
  WORLD.traps.forEach((trap,i)=>{
    if(trap.owner!=='player'&&dist(player,{x:trap.x+.5,y:trap.y+.5})<.8){
      dealDamage({name:'TRAP',id:'_trap'},player,trap.dmg);
      player.stunTimer=CFG.TRAP_STUN_MS;
      addLog('🪤 YOU HIT A TRAP! Stunned 5s!','dmg');showToast('TRAPPED! 5s STUN','err');
      WORLD.traps.splice(i,1);
    }
  });
  drawMinimap();updateHUD();
  requestAnimationFrame(renderFrame);
}

function updateProjectiles(dt){
  WORLD.projectiles.forEach((p,i)=>{
    const dx=p.tx-p.x,dy=p.ty-p.y,d=Math.sqrt(dx*dx+dy*dy)||1;
    p.x+=dx/d*p.spd*(dt/1000);p.y+=dy/d*p.spd*(dt/1000);p.life-=dt;
    if(p.life<=0||d<.4){
      if(p.dmg>0&&p.target&&p.target.state!=='dead')dealDamage({name:'arrow',id:'_proj'},p.target,p.dmg);
      WORLD.projectiles.splice(i,1);
    }
  });
}

function handleMovement(dt){
  if(player.stunTimer>0)return;
  const spd=player.spd*(player.slowTimer>0?.4:1);
  let dx=0,dy=0;
  if(keys['w']||keys['arrowup']){dx-=.7;dy-=.7;}
  if(keys['s']||keys['arrowdown']){dx+=.7;dy+=.7;}
  if(keys['a']||keys['arrowleft']){dx-=.7;dy+=.7;}
  if(keys['d']||keys['arrowright']){dx+=.7;dy-=.7;}
  if(dx||dy){
    const len=Math.sqrt(dx*dx+dy*dy);
    const nx=player.x+dx/len*spd*(dt/1000),ny=player.y+dy/len*spd*(dt/1000);
    if(isPassable(nx|0,player.y|0))player.x=Math.max(.5,Math.min(CFG.MAP_W-.5,nx));
    if(isPassable(player.x|0,ny|0))player.y=Math.max(.5,Math.min(CFG.MAP_H-.5,ny));
  }
}

// ── HUD ──────────────────────────────────────────────
function updateHUD(){
  document.getElementById('hpBar').style.width=(Math.max(0,player.hp)/player.maxHp*100)+'%';
  document.getElementById('mpBar').style.width=(Math.max(0,player.mp)/player.maxMp*100)+'%';
  document.getElementById('xpBar').style.width=(player.xp/player.xpNext*100)+'%';
  document.getElementById('hpVal').textContent=Math.max(0,Math.ceil(player.hp))+'/'+player.maxHp;
  document.getElementById('mpVal').textContent=Math.max(0,Math.ceil(player.mp))+'/'+player.maxMp;
  document.getElementById('xpVal').textContent=player.xp+'/'+player.xpNext;
  document.getElementById('charClass').textContent=getClass(player.level)+' LV.'+player.level;
}
function updateTopBar(){
  document.getElementById('tbName').textContent=player.name;
  document.getElementById('tbSol').textContent=player.sol.toFixed(4);
  document.getElementById('tbLevel').textContent=player.level;
  document.getElementById('tbKills').textContent=player.kills;
  const alive=1+bots.filter(b=>b.state!=='dead').length+(heroEntity&&heroEntity.state!=='dead'?1:0);
  document.getElementById('tbOnline').textContent=alive;
}
function getClass(lv){return lv<3?'WANDERER':lv<6?'FIGHTER':lv<10?'WARRIOR':'LEGEND';}

function updatePlayersList(){
  const el=document.getElementById('playersList');
  const all=[player,...bots.filter(b=>b.state!=='dead')];
  if(heroEntity&&heroEntity.state!=='dead')all.unshift(heroEntity);
  el.innerHTML=all.map(e=>`
    <div class="player-row ${e===player?'self':''} ${e.isHero?'hero-row':''}"
         onclick="${e===player?'':(`attackTarget('${e.id}')`)}">
      <div class="pr-name">${(e.isHero?'👑':'')+e.name.slice(0,7)} <span class="pr-lvl">LV${e.isHero?'MAX':e.level||1}</span></div>
      <div class="pr-hp"><div class="pr-hp-fill" style="width:${Math.max(0,e.hp/e.maxHp*100)}%"></div></div>
      <div class="pr-sol">${e.isHero?'🏆 +0.5 SOL (LV3-5 last hit)':'💰 '+e.sol.toFixed(4)+' SOL'} ${e===player?'(YOU)':''}</div>
      ${e.stunTimer>0?`<div class="pr-stun">🔒 STUNNED ${Math.ceil(e.stunTimer/1000)}s</div>`:''}
      <span class="pr-badge">${e===player?'🟢':e.isHero?'👑':'⚔️'}</span>
    </div>`).join('');
}

function renderInventory(){
  const slots=Array(16).fill(null);
  player.inventory.forEach((item,i)=>{if(i<16)slots[i]=item;});
  document.getElementById('invGrid').innerHTML=slots.map(s=>{
    const upg=s?upgrades[s.id]:null;
    const tier=upg?upg.level:0;
    const equipped=s&&Object.values(player.equipped).includes(s.id);
    return`<div class="inv-slot ${equipped?'equipped':''}">
      ${s?s.icon:''}
      ${tier>0?`<span class="upg-star">★${tier}</span>`:''}
    </div>`;
  }).join('');
}

function drawCharSprite(){
  const c=document.getElementById('charCanvas');const x=c.getContext('2d');
  x.clearRect(0,0,48,48);
  x.fillStyle='#39ff7e';x.fillRect(16,20,16,16);
  x.fillStyle='#ffe0b2';x.fillRect(17,9,14,12);
  x.fillStyle='#000';x.fillRect(20,13,3,3);x.fillRect(26,13,3,3);
  x.fillStyle='#c77dff';x.fillRect(17,9,14,3);
